class Solution:
    def canConstruct(self, ransomNote: str, magazine: str) -> bool:
        seen_m = {}
        for char in magazine:
            if char in seen_m:
                seen_m[char] += 1
            else:
                seen_m[char] = 1

        for char in ransomNote:
            if char not in seen_m or seen_m[char] == 0:
                return False
            seen_m[char] -= 1

        return True
